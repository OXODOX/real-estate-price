# 백엔드 환경변수 템플릿.
# 로컬 개발: 이 파일을 `.env` 로 복사해 실제 값을 채우세요.
# Render 배포: Render 대시보드 → Environment 에 동일 키 입력.

# ─── MOLIT 실거래가 OpenAPI (공공데이터포털) ───
DATA_GO_KR_API_KEY=your_encoded_api_key_here

# ─── 카카오 REST API (백엔드 지오코딩용, 프론트 JS 키와 별개) ───
KAKAO_REST_API_KEY=your_kakao_rest_key_here

# ─── 행정안전부 도로명주소 검색 ───
JUSO_API_KEY=your_juso_key_here

# ─── 건축물대장 정보 서비스 ───
BLDG_REG_API_KEY=your_bldg_key_here

# ─── VWorld (법정동코드 조회) ───
VWORLD_API_KEY=your_vworld_key_here

# ─── CORS (프론트 도메인을 콤마로 구분) ───
# 로컬에서는 비워두면 모든 origin 허용. 운영에서는 Vercel URL 을 지정.
# 예) ALLOWED_ORIGINS=https://real-estate-price.vercel.app
ALLOWED_ORIGINS=

# ─── Mask Service (선택) ───
# 마스킹 지번 복원을 외부 PC(bldg.db 보유)에서 수행할 때만 설정.
# 로컬에서 bldg.db 를 직접 쓰는 경우엔 비워두면 됨.
# Render 배포본에서는 사용자 PC 의 Cloudflare Tunnel URL 을 지정.
# 예) MASK_SERVICE_URL=https://mask.my-domain.com/enrich-masked
MASK_SERVICE_URL=
# 공유 토큰 (임의 문자열). mask-service 와 값이 일치해야 호출 허용됨.
MASK_SERVICE_TOKEN=
# 원격 호출 타임아웃(초). 기본 10.
MASK_SERVICE_TIMEOUT=10
